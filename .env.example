# --- Option A: embedded PGlite (default, no Docker) ---
USE_PGLITE=1
# PGLITE_DATA_DIR=.dev-pglite-data

# --- Option B: real PostgreSQL (after `docker compose up -d`) ---
# USE_PGLITE=0
# DATABASE_URL="postgresql://user:password@localhost:5432/web3_fashion?schema=public"

PORT=3000
FOUNDER_FIDS="1"

# Farcaster public URL (must be HTTPS). Warpcast Embed Tool needs this.
# Recommended: npm run tunnel  (Cloudflare trycloudflare.com)
# NOT for Warpcast: npm run tunnel:lt  (localtunnel blocks crawlers)
# APP_URL=https://something.trycloudflare.com

# Required to resolve Farcaster cast links to their FitPic image.
# Free tier: https://neynar.com  -> create app -> copy API key.
# NEYNAR_API_KEY=
