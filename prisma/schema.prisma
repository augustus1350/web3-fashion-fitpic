generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserTier {
  ROOKIE
  VERIFIED_CREATOR
  ELITE_CURATOR
}

enum SubmissionStatus {
  PENDING
  FLAGGED
  REJECTED
}

enum EpochPhase {
  SUBMISSION
  VOTING
  ENDED
}

enum FounderReviewAction {
  APPROVE
  REJECT
}

model User {
  id              String   @id @default(cuid())
  farcasterFid    Int      @unique
  walletAddress   String?
  socialPoints    Int      @default(0)
  reputationScore Int      @default(0)
  tier            UserTier @default(ROOKIE)
  isBlocked       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  submissions        Submission[]
  votes              Vote[]
  dailyChannelPosts  DailyChannelPost[]

  @@index([tier])
  @@index([isBlocked])
}

model Submission {
  id                 String           @id @default(cuid())
  userId             String
  epochId            String
  farcasterCastHash  String           @unique
  imageUrl           String
  status             SubmissionStatus @default(PENDING)
  hasPhysicalProof   Boolean          @default(false)
  timestamp          DateTime         @default(now())
  totalVotes         Int              @default(0)
  visibilityBoost    Int              @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  epoch  Epoch  @relation(fields: [epochId], references: [id], onDelete: Cascade)
  votes  Vote[]

  @@index([epochId, status])
  @@index([userId])
  @@index([totalVotes])
}

model Vote {
  id                      String   @id @default(cuid())
  userId                  String
  submissionId            String
  voteCountAtTimeOfVoting Int
  reputationReward        Int      @default(0)
  socialPointsReward      Int      @default(0)
  trendsetterMultiplier   Float    @default(1.0)
  timestamp               DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([userId, submissionId])
  @@index([submissionId])
}

model Epoch {
  id        String     @id @default(cuid())
  phase     EpochPhase
  startTime DateTime
  endTime   DateTime
  createdAt DateTime   @default(now())

  submissions Submission[]

  @@index([phase, startTime, endTime])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminFid  Int
  action    String
  targetFid Int?
  reason    String
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([adminFid])
  @@index([targetFid])
}

/// Tracks channel posts processed per user per UTC day (first-post-of-day gate).
model DailyChannelPost {
  id            String   @id @default(cuid())
  userId        String
  castHash      String   @unique
  pointsAwarded Int
  postDate      DateTime @db.Date
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postDate])
}
