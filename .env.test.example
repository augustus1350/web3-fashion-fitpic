# Integration tests default to embedded PGlite (no Docker/Postgres required).
FOUNDER_FIDS=1

# --- Optional: use real PostgreSQL instead of PGlite ---
# 1. Start the test database:
#    npm run test:integration:docker
# 2. Uncomment and set:
# FORCE_TEST_POSTGRES=1
# TEST_DATABASE_URL=postgresql://test:test@localhost:5433/web3_fashion_test?schema=public
#
# STRICT_TEST_POSTGRES=1  # fail if Postgres is down (no PGlite fallback)
